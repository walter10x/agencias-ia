# Evolution API - WhatsApp Gateway Configuration
# Documentación: https://doc.evolution-api.com

# Server
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://localhost:8080

# WhatsApp Integration
DEL_INSTANCE=false
STORE_MESSAGES=true
STORE_MESSAGE_UP=true
STORE_CONTACTS=true
STORE_CHATS=true

# RabbitMQ / Redis (opcional para Evolution)
CACHE_REDIS_ENABLED=false

# Seguridad
AUTHENTICATION_API_KEY=change-me-to-a-secure-key
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=false

# Límites
QRCODE_LIMIT=30
WEBSOCKET_ENABLED=true
WEBSOCKET_GLOBAL_EVENTS=false

# Webhook Global (tus eventos se enviarán aquí)
WEBHOOK_GLOBAL_ENABLED=false

# Logs
LOG_LEVEL=ERROR
LOG_COLOR=true
LOG_BAILEYS=error

# Base de datos SQLite
DATABASE_ENABLED=true
DATABASE_PROVIDER=sqlite
DATABASE_URI=sqlite:///evolution/instances/evolution.sqlite